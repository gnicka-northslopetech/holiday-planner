<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} - Trip Plan</title>

<!-- WhatsApp OG preview -->
<meta property="og:title" content="{{ title }} — {{ subtitle }}">
<meta property="og:description" content="{{ date_range | replace('&ndash;', '–') }} · {{ group_info }} · Powered by TripForge">
<meta property="og:type" content="website">

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: #0a0a0a;
    color: #e8e8e8;
    line-height: 1.6;
    min-height: 100vh;
  }

  .hero {
    background: linear-gradient(135deg, #0077b6 0%, #00b4d8 50%, #90e0ef 100%);
    padding: 60px 24px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.15);
  }

  .hero * { position: relative; z-index: 1; }

  .hero h1 {
    font-size: 2.8rem;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 8px;
    color: #fff;
  }

  .hero .subtitle {
    font-size: 1.2rem;
    font-weight: 300;
    color: rgba(255,255,255,0.9);
    margin-bottom: 4px;
  }

  .hero .dates {
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    background: rgba(0,0,0,0.2);
    display: inline-block;
    padding: 6px 20px;
    border-radius: 20px;
    margin-top: 12px;
  }

  /* Route map in hero */
  .route-map {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-top: 24px;
    flex-wrap: wrap;
    padding: 0 20px;
  }

  .route-stop {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    background: rgba(0,0,0,0.25);
    padding: 6px 14px;
    border-radius: 16px;
    white-space: nowrap;
  }

  .route-arrow {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    padding: 0 6px;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section {
    margin: 32px 0;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: #00b4d8;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid #1a1a1a;
  }

  .day-card {
    background: #111;
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 16px;
    border-left: 3px solid #00b4d8;
  }

  .day-card.highlight {
    border-left-color: #f4a261;
  }

  .day-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 4px;
  }

  .day-card .day-sub {
    font-size: 0.85rem;
    color: #00b4d8;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .day-card p, .day-card li {
    font-size: 0.92rem;
    color: #b0b0b0;
  }

  .day-card ul {
    list-style: none;
    padding: 0;
  }

  .day-card ul li {
    padding: 4px 0 4px 16px;
    position: relative;
  }

  .day-card ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00b4d8;
  }

  .transport-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 4px;
    margin-right: 6px;
    margin-bottom: 6px;
  }

  .badge-flight { background: #1a3a4a; color: #90e0ef; }
  .badge-ferry { background: #1a3a2a; color: #90efbf; }
  .badge-taxi { background: #3a3a1a; color: #efe090; }

  .accommodation {
    background: #151515;
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .accommodation:hover { background: #1a1a1a; }

  .accommodation .info h4 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #e8e8e8;
    margin-bottom: 2px;
  }

  .accommodation .info .location {
    font-size: 0.8rem;
    color: #777;
  }

  .accommodation .price-block {
    text-align: right;
    flex-shrink: 0;
    margin-left: 16px;
  }

  .accommodation .price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
  }

  .accommodation .per-night {
    font-size: 0.7rem;
    color: #666;
  }

  .accommodation .rating {
    font-size: 0.75rem;
    font-weight: 600;
    color: #f4a261;
  }

  /* Accommodation collapse */
  details.acc-more summary {
    font-size: 0.8rem;
    color: #00b4d8;
    cursor: pointer;
    padding: 8px 0;
    list-style: none;
  }
  details.acc-more summary::-webkit-details-marker { display: none; }

  a.book-link {
    color: #00b4d8;
    text-decoration: none;
    font-weight: 500;
  }

  a.book-link:hover { text-decoration: underline; }

  .cost-table {
    width: 100%;
    border-collapse: collapse;
  }

  .cost-table tr {
    border-bottom: 1px solid #1a1a1a;
  }

  .cost-table td {
    padding: 10px 0;
    font-size: 0.9rem;
  }

  .cost-table td:first-child { color: #b0b0b0; }
  .cost-table td:last-child { text-align: right; color: #fff; font-weight: 500; }

  .cost-table tr.total td {
    padding-top: 16px;
    font-size: 1.05rem;
    font-weight: 700;
    color: #00b4d8;
    border-top: 2px solid #00b4d8;
  }

  /* Cost tabs for multi-origin */
  .cost-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 16px;
  }

  .cost-tab {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    background: #1a1a1a;
    color: #888;
    border: none;
  }

  .cost-tab.active {
    background: #00b4d8;
    color: #000;
  }

  .cost-panel { display: none; }
  .cost-panel.active { display: block; }

  .urgency-list {
    list-style: none;
    padding: 0;
    counter-reset: urgency;
  }

  .urgency-list li {
    counter-increment: urgency;
    padding: 14px 16px 14px 52px;
    background: #111;
    border-radius: 8px;
    margin-bottom: 8px;
    position: relative;
    font-size: 0.9rem;
    color: #b0b0b0;
  }

  .urgency-list li::before {
    content: counter(urgency);
    position: absolute;
    left: 16px;
    top: 14px;
    width: 24px;
    height: 24px;
    background: #00b4d8;
    color: #000;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .urgency-list li strong { color: #e8e8e8; }

  .urgency-list li a {
    color: #00b4d8;
    text-decoration: none;
  }

  .links-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .link-card {
    background: #111;
    border-radius: 8px;
    padding: 16px;
    text-decoration: none;
    transition: background 0.2s;
    display: block;
  }

  .link-card:hover { background: #1a1a1a; }

  .link-card .link-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: #666;
    margin-bottom: 4px;
  }

  .link-card .link-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #00b4d8;
  }

  .note {
    background: #1a1a0a;
    border-left: 3px solid #f4a261;
    border-radius: 0 8px 8px 0;
    padding: 14px 18px;
    margin: 12px 0;
    font-size: 0.85rem;
    color: #ccc;
  }

  .note strong { color: #f4a261; }

  /* Booking checklist */
  .checklist {
    list-style: none;
    padding: 0;
  }

  .checklist li {
    padding: 10px 16px;
    background: #111;
    border-radius: 8px;
    margin-bottom: 6px;
    font-size: 0.88rem;
    color: #b0b0b0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .checklist li input[type="checkbox"] {
    accent-color: #00b4d8;
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .checklist li.checked {
    opacity: 0.5;
    text-decoration: line-through;
  }

  /* Sticky bottom bar */
  .sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(17,17,17,0.95);
    backdrop-filter: blur(10px);
    border-top: 1px solid #222;
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    max-width: 100%;
  }

  .sticky-bar .cost-summary {
    font-size: 0.85rem;
    color: #888;
  }

  .sticky-bar .cost-summary strong {
    color: #00b4d8;
    font-size: 1rem;
  }

  .sticky-bar .share-btn {
    background: #00b4d8;
    color: #000;
    border: none;
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }

  .sticky-bar .share-btn:hover { background: #00c8f0; }

  .footer {
    text-align: center;
    padding: 40px 20px 100px;
    color: #444;
    font-size: 0.8rem;
  }

  @media (max-width: 600px) {
    .hero h1 { font-size: 2rem; }
    .hero { padding: 40px 16px 36px; }
    .links-grid { grid-template-columns: 1fr; }
    .accommodation { flex-direction: column; align-items: flex-start; }
    .accommodation .price-block { text-align: left; margin-left: 0; margin-top: 8px; }
    .route-stop { font-size: 0.75rem; padding: 4px 10px; }
  }
</style>
</head>
<body>

<div class="hero">
  <h1>{{ title }}</h1>
  <div class="subtitle">{{ subtitle }}</div>
  <div class="dates">{{ date_range }} &middot; {{ group_info }}</div>
  {% if route_summary %}
  <div class="route-map">
    {% for stop in route_summary %}
    <span class="route-stop">{{ stop }}</span>
    {% if not loop.last %}<span class="route-arrow">&rarr;</span>{% endif %}
    {% endfor %}
  </div>
  {% endif %}
</div>

<div class="container">

  <!-- ITINERARY -->
  <div class="section">
    <div class="section-title">Itinerary</div>

    {% for day in days %}
    <div class="day-card{{ ' highlight' if day.is_highlight else '' }}">
      <h3>{{ day.date_label }} &mdash; {{ day.title }}</h3>
      {% if day.subtitle %}<div class="day-sub">{{ day.subtitle }}</div>{% endif %}

      {% for leg in day.transport_legs %}
      <p><span class="transport-badge {{ leg.badge_class }}">{{ leg.mode.value | upper }}</span> {{ leg.description }}</p>
      {% if leg.options %}
      <ul>
        {% for opt in leg.options %}
        <li>{{ opt.airline }}{% if opt.price_amount %} from {{ opt.price_currency }}{{ opt.price_amount | int }}{% endif %}</li>
        {% endfor %}
      </ul>
      {% endif %}
      {% if leg.notes %}<p style="font-size:0.85rem;color:#888;margin-top:4px">{{ leg.notes }}</p>{% endif %}
      {% if not loop.last %}<br>{% endif %}
      {% endfor %}

      {% if day.highlights %}
      <ul>
        {% for h in day.highlights %}
        <li>{{ h }}</li>
        {% endfor %}
      </ul>
      {% endif %}

      {% for note in day.notes %}
      <div class="note">{{ note }}</div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>

  <!-- ACCOMMODATION -->
  {% for section in accommodation_sections %}
  <div class="section">
    <div class="section-title">{{ section.title }}</div>

    {% for opt in section.options[:3] %}
    <a href="{{ opt.booking_url }}" target="_blank" class="accommodation">
      <div class="info">
        <h4>{{ opt.name }}</h4>
        <div class="location">{{ opt.location }}{% if opt.features %} &middot; {{ opt.features | join(' &middot; ') }}{% endif %}</div>
        <div class="rating">{{ opt.rating }} / {{ opt.rating_max | int }}{% if opt.num_reviews %} ({{ opt.num_reviews }} reviews){% endif %}</div>
      </div>
      <div class="price-block">
        <div class="price">{% if opt.price_currency == 'USD' %}${% elif opt.price_currency == 'GBP' %}&pound;{% else %}&euro;{% endif %}{{ opt.price_per_night | int }}</div>
        <div class="per-night">per night &middot; ~{% if opt.price_currency == 'USD' %}${% elif opt.price_currency == 'GBP' %}&pound;{% else %}&euro;{% endif %}{{ opt.total_price | int }} total</div>
      </div>
    </a>
    {% endfor %}

    {% if section.options | length > 3 %}
    <details class="acc-more">
      <summary>Show {{ section.options | length - 3 }} more options</summary>
      {% for opt in section.options[3:] %}
      <a href="{{ opt.booking_url }}" target="_blank" class="accommodation">
        <div class="info">
          <h4>{{ opt.name }}</h4>
          <div class="location">{{ opt.location }}{% if opt.features %} &middot; {{ opt.features | join(' &middot; ') }}{% endif %}</div>
          <div class="rating">{{ opt.rating }} / {{ opt.rating_max | int }}{% if opt.num_reviews %} ({{ opt.num_reviews }} reviews){% endif %}</div>
        </div>
        <div class="price-block">
          <div class="price">{% if opt.price_currency == 'USD' %}${% elif opt.price_currency == 'GBP' %}&pound;{% else %}&euro;{% endif %}{{ opt.price_per_night | int }}</div>
          <div class="per-night">per night &middot; ~{% if opt.price_currency == 'USD' %}${% elif opt.price_currency == 'GBP' %}&pound;{% else %}&euro;{% endif %}{{ opt.total_price | int }} total</div>
        </div>
      </a>
      {% endfor %}
    </details>
    {% endif %}
  </div>
  {% endfor %}

  <!-- COSTS -->
  {% if cost_breakdowns %}
  <div class="section">
    <div class="section-title">Estimated Costs Per Person</div>

    {% if cost_breakdowns | length > 1 %}
    <div class="cost-tabs">
      {% for cb in cost_breakdowns %}
      <button class="cost-tab{{ ' active' if loop.first else '' }}" onclick="showCostTab({{ loop.index0 }})">{{ cb.origin_label }}</button>
      {% endfor %}
    </div>
    {% endif %}

    {% for cb in cost_breakdowns %}
    <div class="day-card cost-panel{{ ' active' if loop.first else '' }}" id="cost-{{ loop.index0 }}">
      {% if cost_breakdowns | length <= 1 %}
      <p style="font-size:0.8rem;color:#666;margin-bottom:12px">{{ cb.origin_label }}</p>
      {% endif %}
      <table class="cost-table">
        {% for item in cb.line_items %}
        <tr><td>{{ item.label }}</td><td>{{ item.amount_display }}</td></tr>
        {% endfor %}
        <tr class="total"><td>Total per person (approx)</td><td>{{ cb.total_display }}</td></tr>
      </table>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- BOOK NOW -->
  {% if action_items %}
  <div class="section">
    <div class="section-title">What to Book Now (in order of urgency)</div>
    <ol class="urgency-list">
      {% for action in action_items %}
      <li><strong>{{ action.title }}</strong> &mdash; {{ action.reason }}{% for label, url in action.links %} <a href="{{ url }}" target="_blank">{{ label }}</a>{% if not loop.last %} &middot;{% endif %}{% endfor %}</li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  <!-- BOOKING CHECKLIST -->
  {% if action_items %}
  <div class="section">
    <div class="section-title">Booking Checklist</div>
    <ul class="checklist" id="checklist">
      {% for action in action_items %}
      <li data-key="check-{{ loop.index0 }}">
        <input type="checkbox" onchange="toggleCheck(this)">
        <span>{{ action.title }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- LINKS -->
  {% if useful_links %}
  <div class="section">
    <div class="section-title">Useful Links</div>
    <div class="links-grid">
      {% for link in useful_links %}
      <a href="{{ link.url }}" target="_blank" class="link-card">
        <div class="link-label">{{ link.category }}</div>
        <div class="link-name">{{ link.name }}</div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="footer">
    Generated {{ generated_at }} by TripForge &middot; Prices are estimates, check links for live availability
  </div>

</div>

<!-- Sticky bottom bar -->
{% if cost_breakdowns %}
<div class="sticky-bar">
  <div class="cost-summary">
    Est. per person<br>
    <strong>{{ cost_breakdowns[0].total_display | replace('&euro;', '\u20ac') | replace('&pound;', '\u00a3') }}</strong>
  </div>
  <button class="share-btn" onclick="shareTrip()">Share Plan</button>
</div>
{% endif %}

<script>
// ~50 lines of progressive enhancement JS

// Cost tabs
function showCostTab(idx) {
  document.querySelectorAll('.cost-tab').forEach((t, i) => t.classList.toggle('active', i === idx));
  document.querySelectorAll('.cost-panel').forEach((p, i) => p.classList.toggle('active', i === idx));
}

// Booking checklist with localStorage
function toggleCheck(cb) {
  var li = cb.closest('li');
  var key = li.dataset.key;
  if (cb.checked) {
    li.classList.add('checked');
    localStorage.setItem(key, '1');
  } else {
    li.classList.remove('checked');
    localStorage.removeItem(key);
  }
}

// Restore checklist state
document.querySelectorAll('.checklist li').forEach(function(li) {
  var key = li.dataset.key;
  if (localStorage.getItem(key)) {
    li.classList.add('checked');
    li.querySelector('input').checked = true;
  }
});

// Share button
function shareTrip() {
  if (navigator.share) {
    navigator.share({
      title: document.title,
      url: window.location.href,
    });
  } else {
    navigator.clipboard.writeText(window.location.href).then(function() {
      var btn = document.querySelector('.share-btn');
      btn.textContent = 'Link Copied!';
      setTimeout(function() { btn.textContent = 'Share Plan'; }, 2000);
    });
  }
}
</script>

</body>
</html>
